# Skopiuj do `.env` obok `package.json` (`03_01_zadanie/.env`).
# Sekrety nie commitujemy — globalny `.gitignore` ignoruje `.env`.
#
# Kolejność wczytywania: zmienne środowiskowe procesu → ten plik → `.env` w root repozytorium.

# OPENROUTER_API_KEY — ustaw w root `.env`; lokalnie nie jest potrzebny.

# AG3NTS_API_KEY dla /verify (`apikey` w payloadzie) — tu albo w root `.env`.
# Nie dodawaj pustego `AG3NTS_API_KEY=` — zablokuje wartość z root.
# AG3NTS_API_KEY=

# Tani model (Haiku na OpenRouter) — dokładny identyfikator modelu użyty w żądaniach.
CHEAP_MODEL=anthropic/claude-3-5-haiku

# Endpointy centrali — jawne w lokalnym `.env`.
SENSORS_ZIP_URL=https://hub.ag3nts.org/dane/sensors.zip
VERIFY_URL=https://hub.ag3nts.org/verify
